# BBSM Mobile App — Environment Variables
# Copy to .env and fill in values.
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible in the app.

# Backend API base URL
# Development (local): http://localhost:4000
# Development (physical device): http://<your-machine-local-ip>:4000
# Production: https://api.bbsm.com.np
EXPO_PUBLIC_API_URL=http://localhost:4000
